	measure 'KPI Spark ATV' = VAR _months = CALCULATETABLE ( SUMMARIZE ( 'dim_date', 'dim_date'[calendar_year], 'dim_date'[month_of_year] ), ALLSELECTED ( 'dim_date' ) ) VAR _t = ADDCOLUMNS ( _months, "@idx", ( 'dim_date'[calendar_year] - 2024 ) * 12 + 'dim_date'[month_of_year], "@v", CALCULATE ( [Avg Transaction Value] ) ) VAR _nb = FILTER ( _t, NOT ISBLANK ( [@v] ) ) VAR _minI = MINX ( _t, [@idx] ) VAR _maxI = MAXX ( _t, [@idx] ) VAR _spanI = _maxI - _minI VAR _maxV = MAXX ( _t, [@v] ) VAR _pts = CONCATENATEX ( _nb, ROUND ( IF ( _spanI = 0, 50, DIVIDE ( [@idx] - _minI, _spanI ) * 100 ), 1 ) & "," & ROUND ( 28 - DIVIDE ( [@v], _maxV ) * 26, 1 ), " ", [@idx], ASC ) VAR _svg = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 30'><polyline points='" & _pts & "' fill='none' stroke='#157A52' stroke-width='2.5'/></svg>" RETURN IF ( ISBLANK ( _pts ) || _maxV = 0 || COUNTROWS ( _nb ) < 2, BLANK (), _svg )
		displayFolder: SVG KPI
		lineageTag: 1a2b3c4d-9004-4a00-9000-000000000001
		dataCategory: ImageUrl

