ze='15' font-weight='600' fill='#5B6573'>UNITS / TRANSACTION</text>" & _spark & "<text x='20' y='92' font-family='Segoe UI Semibold, Segoe UI, sans-serif' font-size='46' font-weight='700' fill='#10151C'>" & _num & "</text><g transform='translate(20,112)'><rect x='0' y='0' width='" & FORMAT ( _chipw, "0" ) & "' height='30' rx='15' fill='" & _bg & "'/><g transform='translate(10,6)'>" & _arrow & "</g><text x='26' y='20' font-family='Segoe UI, sans-serif' font-size='14.5' font-weight='600' fill='" & _col & "'>" & _chip & "</text></g></svg>" RETURN _svg
